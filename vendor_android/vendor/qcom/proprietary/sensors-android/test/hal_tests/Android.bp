cc_binary {
    name: "sns_hal_batch",
    defaults: [
        "sns_direct_channel",
    ],
    owner: "qti",
    proprietary: true,
    srcs: [
        "sns_hal_batch_fmq.cpp",
        "convert.cpp",
    ],
    cflags: [
        "-Werror",
        "-Wno-unused-variable",
        "-Wno-unused-parameter",
    ],
    local_include_dirs: ["./"],
    header_libs: [
        "libsnshal_headers",
        "libsensorutils_headers",
        "libfastrpc_vendor_headers",
        "android.hardware.sensors@2.X-multihal.header",
        "libimapper_stablec",
        "libimapper_providerutils",
        "common_interface_headers",
        "libsensinghubcommon_headers",
    ],
    shared_libs: [
        "libhardware",
        "libbase",
        "libfmq",
        "libcutils",
        "libutils",
        "liblog",
        "libhidlbase",
        "libhardware",
        "libdl",
        "android.hardware.sensors@2.0",
        "android.hardware.sensors@2.1",
        "libc",
        "sensors.qsh",
        "android.hardware.graphics.allocator-V2-ndk",
        "mapper.qti",
        "libsnsutils",
        "libsensinghubsession",
        "libsensinghubapi",
        "libsensinghubapi-prop",
        "libsuidlookup",
    ],
}

