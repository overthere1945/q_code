cc_binary {
    name: "sensors.debug",
    defaults: ["sns_proto_lib_name-lite"],
    local_include_dirs: [
        "src",
    ],
    srcs: [
        "src/sensordaemon.cpp",
    ],
    header_libs: [
        "vendor_common_inc",
        "libdiag_headers",
        "libsensorutils_headers",
    ],
    shared_libs: [
        "liblog",
        "libdiag",
        "libcutils",
        "libsnsutils",
    ],
    cflags: [
        "-Werror",
        "-Wall",
        "-fexceptions",
    ],
    proprietary: true,
    owner: "qti",
    init_rc: ["vendor.sensors.debug.rc"],
}

prebuilt_etc {
    name: "init.vendor.sensors.rc",
    src: "init.vendor.sensors.rc",
    sub_dir: "init",
    proprietary: true,
}

prebuilt_etc {
    name: "init.vendor.sensors.glink.rc",
    src: "init.vendor.sensors.glink.rc",
    sub_dir: "init",
    proprietary: true,
}

sh_binary {
    name: "init.qcom.sensors.sh",
    src: "init.qcom.sensors.sh",
    vendor: true,
    owner: "qti",
    proprietary: true,
}
