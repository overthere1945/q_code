cc_defaults {
    name: "libsnsapi-defaults",
    rtti: false,
    srcs: [
        "client_api/sns_client_api_v01.c",
        "google/protobuf/descriptor.proto",
        "nanopb.proto",
        "sns_std_sensor.proto",
        "sns_gravity.proto",
        "sns_device_orient.proto",
        "sns_rotv.proto",
        "sns_tilt_to_wake.proto",
        "sns_heart_beat.proto",
        "sns_wrist_tilt_gesture.proto",
        "sns_gyro_rot_matrix.proto",
        "sns_tilt.proto",
        "sns_step_detect.proto",
        "sns_game_rv.proto",
        "sns_registry.proto",
        "sns_geomag_rv.proto",
        "sns_amd.proto",
        "sns_da_test.proto",
        "sns_dpc.proto",
        "sns_pedometer.proto",
        "sns_pose_6dof.proto",
        "sns_persist_stationary_detect.proto",
        "sns_persist_motion_detect.proto",
        "sns_physical_sensor_test.proto",
        "sns_sar.proto",
        "sns_ppg.proto",
        "sns_std_event_gated_sensor.proto",
        "sns_hall.proto",
        "sns_heart_rate.proto",
        "sns_sig_motion.proto",
        "sns_cal.proto",
        "sns_ambient_temperature.proto",
        "sns_ambient_light.proto",
        "sns_accel_cal.proto",
        "sns_gyro.proto",
        "sns_proximity.proto",
        "sns_thermopile.proto",
        "sns_gyro_cal.proto",
        "sns_accel.proto",
        "sns_mag_cal.proto",
        "sns_sensor_temperature.proto",
        "sns_rgb.proto",
        "sns_mag.proto",
        "sns_pressure.proto",
        "sns_ultra_violet.proto",
        "sns_device_mode.proto",
        "sns_offbody_detect.proto",
        "sns_aont.proto",
        "sns_std_type.proto",
        "sns_std.proto",
        "sns_suid.proto",
        "sns_client.proto",
        "sns_diag.proto",
        "sns_diag_sensor.proto",
        "sns_humidity.proto",
        "sns_fmv.proto",
        "sns_activity_recognition.proto",
        "sns_hinge_angle.proto",
        "sns_direct_channel.proto",
        "sns_transport_ppe.proto",
        "sns_client_sensor.proto",
    ],
    local_include_dirs: ["./"],
    export_include_dirs: ["client_api/."],
    cppflags: ["-DGOOGLE_PROTOBUF_NO_RTTI"],
    cflags: [
        "-Werror",
        "-Wall",
        "-Wno-unused-parameter",
        "-fexceptions",
    ],
    proto: {
        canonical_path_from_root: false,
        export_proto_headers: true,
        local_include_dirs : ["./"],
    },
    header_libs: [
        "libqmi_encdec_headers",
        "libqmi_common_headers",
    ],
    shared_libs: [
        "libcutils",
        "libutils",
        "libqmi_common_so",
        "libqmi_cci",
        "libqmi_encdec",
    ],
    sanitize:{
        integer_overflow: true,
    },
    owner: "qti",
    proprietary: true,
}

cc_library_shared {
    name: "libsnsapi",
    defaults: [
        "libsnsapi-defaults",
        "sns_proto_lib_name-lite",
    ],
    proto: {
        type: "lite",
    },
}

cc_defaults {
    name: "libqsh-defaults",
    rtti: false,
    srcs: [
        "suid_lookup.cpp",
        "qsh_interface/qsh_interface.cpp",
        "qsh_interface/qsh_qmi.cpp",
        "qsh_interface/qsh_glink.cpp",
        "qsh_interface/qsh_qmi_debug_timer.cpp",
        "qsh_interface/qsh_interface_util.cpp",
    ],
    local_include_dirs: [
        "./",
        "qsh_interface",
    ],
    export_include_dirs: [
        "./",
        "qsh_interface/.",
    ],
    header_libs: [
        "libqmi_encdec_headers",
        "libqmi_common_headers",
        "libsensorutils_headers",
    ],
    cflags: [
        "-Werror",
        "-Wall",
        "-Wno-unused-parameter",
        "-fexceptions",
    ],
    shared_libs: [
        "liblog",
        "libcutils",
        "libutils",
        "libqmi_common_so",
        "libqmi_cci",
        "libqmi_encdec",
        "libsnsutils",
    ],
    sanitize:{
        integer_overflow: true,
    },
    owner: "qti",
    proprietary: true,
}

cc_library_shared {
    name: "libqsh",
    defaults: [
        "libqsh-defaults",
        "sns_proto_lib_name-lite",
    ],
    shared_libs: [
        "libsnsapi",
    ],
}


