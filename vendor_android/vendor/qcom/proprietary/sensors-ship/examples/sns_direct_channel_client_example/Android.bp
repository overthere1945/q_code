cc_binary {
    name: "sns_direct_channel_client_example",
    defaults: [
        "sns_proto_lib_name-lite",
        "sns_direct_channel",
    ],
    owner: "qti",
    proprietary: true,
    srcs: [
        "sns_direct_channel_client.cpp",
    ],
    local_include_dirs: ["./"],
    cflags: [
        "-Wall",
        "-Wextra",
        "-Werror",
        "-Wno-missing-field-initializers",
        "-Wno-maybe-uninitialized",
    ],
    cppflags: ["-fexceptions"],
    header_libs: [
        "libfastrpc_vendor_headers",
        "libsensorutils_headers",
    ],
    shared_libs: [
        "libutils",
        "libcutils",
        "liblog",
        "libsensinghubapi",
        "libsensinghubapi-prop",
        "libsnsutils",
    ],
}
