cc_library_shared {
    name: "libUSTANative",
    defaults: [
        "sns_proto_lib_name-full",
        "sns_direct_channel",
    ],
    owner: "qti",
    proprietary: true,
    srcs: [
        "sensor_cxt.cpp",
        "sensor_suid.cpp",
        "sensor.cpp",
        "sensor_descriptor_pool.cpp",
        "sensor_message_parser.cpp",
        "sensor_attributes.cpp",
        "sensor_direct_channel.cpp",
        "com_qualcomm_qti_usta_core_SensorContextJNI.cpp",
        "data_stream.cpp",
    ],
    local_include_dirs: ["./"],
    cflags: [
        "-Wall",
        "-fexceptions",
    ],
    cppflags: [
            "-DGOOGLE_PROTOBUF_NO_RTTI",
            "-DSNS_SUPPORT_DIRECT_CHANNEL",
            "-DSNS_CLIENT_TECH_ENABLED"
    ],
    sanitize:{
        integer_overflow: true,
    },
    header_libs: [
        "jni_headers",
        "libsnsdiag_headers",
        "libfastrpc_vendor_headers",
        "libsensinghubcommon_headers",
    ],
    shared_libs: [
        "liblog",
        "libutils",
        "libcutils",
        "libsns_device_mode_stub",
        "libqmi_common_so",
        "libqmi_cci",
        "libqmi_encdec",
        "libdiag",
        "libsnsutils",
        "libsensinghubsession",
        "libsensinghubapi",
        "libsensinghubapi-prop",
    ],
    static_libs: [
        "libsnsdiaglog-full-static",
    ],
}

cc_library_headers {
    name: "libUSTANative_headers",
    export_include_dirs: ["./"],
    owner: "qti",
    proprietary: true,
}
