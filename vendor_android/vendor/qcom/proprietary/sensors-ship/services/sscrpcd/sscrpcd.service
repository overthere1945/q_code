[Unit]
Description=sscrpcd Service
SourcePath=/usr/bin/sscrpcd

[Service]
User=system
Group=system
Restart=always
ExecStartPre=+/bin/chown -R system.system /etc/sensors/registry
ExecStartPre=+/bin/chown -R system.system /etc/sensors
ExecStart=/usr/bin/sscrpcd sensorspd

[Install]
WantedBy=multi-user.target
