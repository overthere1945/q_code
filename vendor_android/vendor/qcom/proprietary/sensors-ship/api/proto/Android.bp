cc_library_shared {
    name: "libsensinghubapi-prop",
    defaults: [
        "qshApiDirPath",
    ],
    rtti: false,
    srcs: [
        "sns_tilt_to_wake.proto",
        "sns_heart_beat.proto",
        "sns_wrist_tilt_gesture.proto",
        "sns_gyro_rot_matrix.proto",
        "sns_step_detect.proto",
        "sns_registry.proto",
        "sns_da_test.proto",
        "sns_dpc.proto",
        "sns_pose_6dof.proto",
        "sns_ppg.proto",
        "sns_heart_rate.proto",
        "sns_accel_cal.proto",
        "sns_thermopile.proto",
        "sns_rgb.proto",
        "sns_ultra_violet.proto",
        "sns_offbody_detect.proto",
        "sns_aont.proto",
        "sns_diag.proto",
        "sns_diag_sensor.proto",
        "sns_fmv.proto",
        "sns_activity_recognition.proto",
        "sns_client_sensor.proto",
        "sns_ccd_gesture.proto",
        "sns_delta_angle.proto",
        "sns_client_glink.proto",
        "sns_electro_neuro_graph.proto",
        "sns_client_batch.proto",
        "sns_time.proto",
        "sns_skin_temperature.proto"
    ],
    local_include_dirs: ["./"],
    cppflags: ["-DGOOGLE_PROTOBUF_NO_RTTI"],
    cflags: [
        "-Werror",
        "-Wall",
        "-Wno-unused-parameter",
        "-fexceptions",
    ],
    proto: {
        type: "lite",
        canonical_path_from_root: false,
        export_proto_headers: true,
        local_include_dirs : ["./"],
    },
    shared_libs: [
        "libcutils",
        "libutils",
        "libsensinghubapi",
    ],
    sanitize:{
        integer_overflow: true,
    },
    owner: "qti",
    vendor: true,
}

prebuilt_etc {
    name: "sns_accel_cal.proto",
    src: "sns_accel_cal.proto",
    sub_dir: "sensors/proto",
    vendor: true,
    proprietary: true,
    owner: "qti",
}
