
soong_config_module_type {
    name: "qti_platform_btaudio_cc_defaults",
    module_type: "cc_defaults",
    config_namespace: "qtiplatform",
    bool_variables: [
        "board_platform_version_17",
    ],
    properties: [
        "cflags",
    ],
}

qti_platform_btaudio_cc_defaults {
    name: "qti_platform_version_btaudio_cc_defaults",
    soong_config_variables: {
        board_platform_version_17: {
            cflags: ["-DANDROID_PLATFORM_VERSION_17"],
        },
    },
}

cc_library_shared {
    name: "android.hardware.bluetooth.audio-impl-qti",
    relative_install_path: "hw",
    vendor: true,
    srcs: [
        "BluetoothAudioProvider.cpp",
        "BluetoothAudioProviderFactory.cpp",
        "A2dpOffloadAudioProvider.cpp",
        "A2dpOffloadCodecAac.cpp",
        "A2dpOffloadCodecAptx.cpp",
        "A2dpOffloadCodecAptxHd.cpp",
        "A2dpOffloadCodecAptxAdaptive.cpp",
        "A2dpOffloadCodecFactory.cpp",
        "A2dpOffloadCodecLdac.cpp",
        "A2dpOffloadCodecSbc.cpp",
        "A2dpSoftwareAudioProvider.cpp",
        "HearingAidAudioProvider.cpp",
        "HfpOffloadAudioProvider.cpp",
        "HfpSoftwareAudioProvider.cpp",
        "LeAudioOffloadAudioProvider.cpp",
        "LeAudioSoftwareAudioProvider.cpp",
        "service.cpp",
    ],
    export_include_dirs: ["."],
    header_libs: ["libhardware_headers"],
    defaults: [
        "latest_android_hardware_bluetooth_audio_ndk_shared",
        "qti_platform_version_btaudio_cc_defaults"
    ],
    shared_libs: [
        "libbase",
        "libbinder_ndk",
        "libcutils",
        "libfmq",
        "liblog",
        "libbluetooth_audio_session_aidl_qti",
        "vendor.qti.hardware.bluetooth.btavsprovider-V1-ndk",
        "vendor.qti.hardware.bluetooth.btavsprovider-impl-qti",
    ],
}

cc_fuzz {
    name: "android.bluetooth.audio-aidl_fuzzer",
    vendor:true,
    static_libs: [
                   "libbinder_random_parcel",
                ],
    defaults: [
        "latest_android_hardware_bluetooth_audio_ndk_shared",
    ],
    shared_libs: [
        "libbase",
        "libbinder_ndk",
        "libcutils",
        "libfmq",
        "liblog",
        "libbinder",
        "libutils",
        "libbluetooth_audio_session_aidl_qti",
        "vendor.qti.hardware.bluetooth.btavsprovider-V1-ndk",
        "vendor.qti.hardware.bluetooth.btavsprovider-impl-qti",
    ],
    header_libs: ["libhardware_headers"],
target: {
             android: {
              shared_libs: [
              "libbinder_ndk",
              "libbinder",
              "libutils",
            ],
            },
            darwin: {
             enabled: false,
             },
        },
    srcs: [
           "BluetoothAudioProvider.cpp",
           "BluetoothAudioProviderFactory.cpp",
           "A2dpOffloadAudioProvider.cpp",
           "A2dpSoftwareAudioProvider.cpp",
           "HearingAidAudioProvider.cpp",
           "LeAudioOffloadAudioProvider.cpp",
           "A2dpOffloadCodecAac.cpp",
           "A2dpOffloadCodecFactory.cpp",
           "HfpOffloadAudioProvider.cpp",
           "HfpSoftwareAudioProvider.cpp",
           "A2dpOffloadCodecSbc.cpp",
           "A2dpOffloadCodecAptx.cpp",
           "A2dpOffloadCodecAptxHd.cpp",
           "A2dpOffloadCodecAptxAdaptive.cpp",
           "A2dpOffloadCodecLdac.cpp",
           "LeAudioSoftwareAudioProvider.cpp",
           "fuzzer.cpp",
        ],
}

cc_library_headers {
    name: "audio_bluetooth_aidl_1_default_headers",
    vendor_available: true,
    export_include_dirs: ["."],
}