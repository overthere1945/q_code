cc_library_shared {
    name: "libbluetooth_audio_session_aidl_qti",
    vendor: true,
    srcs: [
        "aidl_session/BluetoothAudioCodecs.cpp",
        "aidl_session/BluetoothAudioSession.cpp",
        "aidl_session/BluetoothLeAudioCodecsProvider.cpp",
        "aidl_session/BluetoothLeAudioAseConfigurationSettingProvider.cpp",
        "aidl_session/btavs_client.cpp",
    ],
    export_include_dirs: ["aidl_session/"],
    header_libs: [
       "libhardware_headers",
       "libxsdc-utils",
    ],
    defaults: [
        "aconfig_lib_cc_static_link.defaults",
        "latest_android_hardware_bluetooth_audio_ndk_shared",
    ],
    shared_libs: [
        "android.hardware.bluetooth.audio@2.0",
        "android.hardware.bluetooth.audio@2.1",
        "libbase",
        "libcutils",
        "libbinder_ndk",
        "libfmq",
        "liblog",
        "libhidlbase",
        "libxml2",
        "libflatbuffers-cpp",
        "server_configurable_flags",
        "vendor.qti.hardware.bluetooth.btavsprovider-V1-ndk",
        "vendor.qti.hardware.bluetooth.btavsprovider-impl-qti",
        "btaudiohal_flags_c_lib",
    ],
    generated_sources: ["le_audio_codec_capabilities"],
    generated_headers: [
        "le_audio_codec_capabilities",
        "AIDLLeAudioSetConfigSchemas_qti_h",
        "AIDLDevice_qti_h",
    ],
    required: [
        "aidl_audio_set_configurations_bfbs",
        "aidl_default_audio_set_configurations_qti_json",
        "aidl_audio_set_scenarios_bfbs",
        "aidl_default_audio_set_scenarios_qti_json",
        "aidl_default_vendor_audio_set_scenarios_qti_json",
    ],
}

/*
cc_test {
    name: "BluetoothLeAudioCodecsProviderTest",
    srcs: [
        "aidl_session/BluetoothLeAudioCodecsProvider.cpp",
        "aidl_session/BluetoothLeAudioCodecsProviderTest.cpp",
    ],
    header_libs: [
        "libxsdc-utils",
    ],
    shared_libs: [
        "libbase",
        "libbinder_ndk",
        "android.hardware.bluetooth.audio-V2-ndk",
        "libxml2",
    ],
    test_suites: [
        "general-tests",
    ],
    test_options: {
        unit_test: false,
    },
    generated_sources: ["le_audio_codec_capabilities"],
    generated_headers: ["le_audio_codec_capabilities"],
}

xsd_config {
    name: "le_audio_codec_capabilities",
    srcs: ["le_audio_codec_capabilities/le_audio_codec_capabilities.xsd"],
    package_name: "aidl.android.hardware.bluetooth.audio.setting",
    api_dir: "le_audio_codec_capabilities/schema",
}
*/

genrule {
    name: "AIDLDevice_qti_h",
    tools: [
        "flatc",
    ],
    cmd: "$(location flatc) -I vendor/qcom/proprietary/bluetooth/bluetooth_audio/utils/aidl_session/ -o $(genDir) --cpp $(in) ",
    srcs: [
        "device.fbs",
    ],
    out: [
        "device_generated.h",
    ],
}

genrule {
    name: "AIDLLeAudioSetConfigSchemas_qti_h",
    tools: [
        "flatc",
    ],
    cmd: "$(location flatc) -I vendor/qcom/proprietary/bluetooth/bluetooth_audio/utils/ -o $(genDir) --cpp $(in) ",
    srcs: [
        "le_audio_configuration_set/audio_set_configurations.fbs",
        "le_audio_configuration_set/audio_set_scenarios.fbs",
    ],
    out: [
        "audio_set_configurations_generated.h",
        "audio_set_scenarios_generated.h",
    ],
}

// Binary generation
genrule {
    name: "AIDLLeAudioSetScenariosSchema_qti_bfbs",
    tools: [
        "flatc",
    ],
    cmd: "$(location flatc) -I vendor/qcom/proprietary/bluetooth/bluetooth_audio/utils/ -b --schema -o $(genDir) $(in) ",
    srcs: [
        "le_audio_configuration_set/audio_set_scenarios.fbs",
    ],
    out: [
        "audio_set_scenarios.bfbs",
    ],
}

genrule {
    name: "AIDLLeAudioSetConfigsSchema_qti_bfbs",
    tools: [
        "flatc",
    ],
    cmd: "$(location flatc) -I vendor/qcom/proprietary/bluetooth/bluetooth_audio/utils/ -b --schema -o $(genDir) $(in) ",
    srcs: [
        "le_audio_configuration_set/audio_set_configurations.fbs",
    ],
    out: [
        "audio_set_configurations.bfbs",
    ],
}

// Add to prebuilt etc
prebuilt_etc {
    name: "aidl_audio_set_scenarios_qti_bfbs",
    src: ":AIDLLeAudioSetScenariosSchema_qti_bfbs",
    filename: "aidl_audio_set_scenarios.bfbs",
    sub_dir: "aidl/le_audio",
    vendor: true,
}

prebuilt_etc {
    name: "aidl_default_audio_set_scenarios_qti_json",
    src: "le_audio_configuration_set/audio_set_scenarios.json",
    filename: "aidl_default_audio_set_scenarios_qti.json",
    sub_dir: "aidl/le_audio",
    vendor: true,
}

prebuilt_etc {
    name: "aidl_audio_set_configurations_qti_bfbs",
    src: ":AIDLLeAudioSetConfigsSchema_qti_bfbs",
    filename: "aidl_audio_set_configurations.bfbs",
    sub_dir: "aidl/le_audio",
    vendor: true,
}

prebuilt_etc {
    name: "aidl_default_audio_set_configurations_qti_json",
    src: "le_audio_configuration_set/audio_set_configurations.json",
    filename: "aidl_default_audio_set_configurations_qti.json",
    sub_dir: "aidl/le_audio",
    vendor: true,
}

prebuilt_etc {
    name: "aidl_default_vendor_audio_set_scenarios_qti_json",
    src: "le_audio_configuration_set/vendor_audio_set_scenarios.json",
    filename: "aidl_default_vendor_audio_set_scenarios_qti.json",
    sub_dir: "aidl/le_audio",
    vendor: true,
}

cc_library_headers {
    name: "audio_bluetooth_utils_headers",
    vendor_available: true,
    export_include_dirs: ["aidl_session/"],
}