cc_library_shared {
    name: "android.hardware.bluetooth.audio_sw",
    vendor: true,
    relative_install_path: "hw",
    proprietary: true,
    srcs: [
        "DevicePortProxy.cpp",
        "ModuleBluetooth.cpp",
        "StreamBluetooth.cpp",
    ],
    header_libs: ["libhardware_headers", "libexpectedutils_headers",],
    include_dirs: [
        "vendor/qcom/proprietary/bluetooth/bluetooth_audio/aidl/1.0/default/",
        "vendor/qcom/proprietary/bluetooth/bluetooth_audio/utils/aidl_session/",
        "hardware/interfaces/audio/aidl/default/include/",
        "hardware/interfaces/audio",
        "hardware/interfaces/audio/aidl/common/include/",
        "frameworks/av/media/liberror/include/error/",
    ],
    defaults: [
        "latest_android_media_audio_common_types_ndk_shared",
        "latest_android_hardware_bluetooth_audio_ndk_shared",
        "latest_android_hardware_audio_core_ndk_shared",
    ],
    shared_libs: [
        "libbluetooth_audio_session_qti",
        "libbluetooth_audio_session_aidl_qti",
        "android.hardware.bluetooth.audio-impl-qti",
        "libaudioserviceexampleimpl",
        "libaudioutils",
        "libaudioaidlcommon",
        "libbinder_ndk",
        "libbase",
        "libcutils",
        "libfmq",
        "libhidlbase",
        "liblog",
        "libutils",
    ],
    vintf_fragments: ["manifest_btaudiocoreservices_qti.xml"],
    cflags: [
        "-Wall",
        "-Werror",
        "-Wno-unused-parameter",
    ],
}
