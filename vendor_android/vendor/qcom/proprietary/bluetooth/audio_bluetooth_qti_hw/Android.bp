// The format of the name is audio.<type>.<hardware/etc>.so

cc_library_shared {
    name: "audio.bluetooth_qti.default",
    vendor: true,
    relative_install_path: "hw",
    proprietary: true,
    srcs: [
        "audio_bluetooth_hw.cc",
        "aidl/audio_bluetooth_hw.cc",
        "aidl/stream_apis.cc",
        "aidl/device_port_proxy.cc",
        "aidl/utils.cc",
    ],
    header_libs: ["libhardware_headers",
                  "audio_bluetooth_aidl_1_default_headers",
                  "audio_bluetooth_utils_headers",
                  "audio_bluetooth_qti_session_headers",
                  "audio_bluetooth_qti_session_headers_v_2_1",
                 ],
    defaults: [
        "latest_android_hardware_bluetooth_audio_ndk_shared",
    ],
    shared_libs: [
        "libbluetooth_audio_session_qti_2_1",
        "libbluetooth_audio_session_qti",
        "libbluetooth_audio_session_aidl_qti",
        "android.hardware.bluetooth.audio-impl-qti",
        "libaudioutils",
        "libbinder_ndk",
        "libbase",
        "libcutils",
        "libfmq",
        "libhidlbase",
        "liblog",
        "libutils",
    ],
    cflags: [
        "-Wall",
        "-Werror",
        "-Wno-unused-parameter",
    ],
}

cc_library_headers {
    name: "audio_bluetooth_qti_hw_headers",
    vendor_available: true,
    export_include_dirs: ["."],
}
